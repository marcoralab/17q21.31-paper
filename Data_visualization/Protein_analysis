make_venn <- function(rna_set, prot_set, title_text, output_name) {

  venn_list <- list(
    RNAseq = rna_set,
    Proteomics = prot_set
  )

  p <- ggVennDiagram(
    venn_list,
    label_alpha = 0,
    category.names = c("RNA-seq", "Proteomics")
  ) +
    labs(title = title_text) +
    theme(
      plot.title = element_text(
        hjust = 0.5,
        face = "bold",
        size = 16
      )
    )

  print(p)

  ggsave(
    output_name,
    plot = p,
    width = 6,
    height = 6,
    dpi = 300
  )
}

