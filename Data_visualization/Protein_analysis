#LmFit and Volcano proteins 
```{r}
rm(list = ls())
library(dplyr)
library(limma)
library(EnhancedVolcano)

# Load metadata and expression data
meta <- read.csv("metadata_CWP4.csv", stringsAsFactors = FALSE)
result <- read.csv("data_CWP4.csv", stringsAsFactors = FALSE, row.names = 1, check.names = FALSE)

# Set cell type
ancestry <- "AA"
  # or whatever your cell type is
cell_type <- "Astrocytes"  
#cell_type <- "Neuron"
# Step 1: Subset metadata

meta_cell <- meta %>%
  filter(Ancestry == ancestry, Haplotype %in% c("H1H1","H1H2","H1H1_A"),CellType == "Astrocytes")
# Set rownames based on sample IDs

rownames(meta_cell) <- meta_cell$X

# Step 2: Match expression matrix to filtered metadata
sample_ids <- rownames(meta_cell)
common_samples <- intersect(sample_ids, colnames(result))

# Subset expression data
df_selected <- result[, common_samples, drop = FALSE]

# Convert to numeric expression matrix
exprs <- as.matrix(df_selected)
mode(exprs) <- "numeric"
exprs[exprs == "NA"] <- NA

# Filter out proteins with too many NAs
keep_genes <- rowSums(!is.na(exprs)) >= (ncol(exprs) / 4)
exprs_filtered <- exprs[keep_genes, , drop = FALSE]

# Step 3: Prepare metadata
metadata <- meta_cell %>%
  mutate(
    haplotype = factor(Haplotype, levels = c("H1H1", "H1H2", "H1H1_A")), # H1H1 = reference
    cell_type = factor(CellType),
    sex = factor(sex),
    donor = factor(Cell_Line)
  ) %>%
  select(haplotype,sex,cell_type, donor)

# Which samples have missing data in any covariate used in the model?
rows_with_na <- which(!complete.cases(metadata[, c("haplotype", "sex","cell_type")]))
print(rownames(metadata)[rows_with_na])

# Reorder expression matrix to match metadata
exprs_filtered <- exprs_filtered[, rownames(metadata), drop = FALSE]

# Step 4: Create design matrix with interaction term
design <- model.matrix(~ haplotype, data = metadata)
print(colnames(design))  # Sanity check

# Step 5: Fit model
fit <- lmFit(exprs_filtered, design)
fit <- eBayes(fit)

# Step 6: Extract effect
# Define the contrasts/effects of interest
library(EnhancedVolcano)

effect_list <- c(
  "haplotypeH1H2",
  "haplotypeH1H1_A")

fdr_cutoff <- 0.05
logfc_cutoff <- 1

for (coef_name in effect_list) {
  if (coef_name %in% colnames(fit$coefficients)) {
    
    deg_results <- topTable(fit, coef = coef_name, number = Inf, adjust.method = "fdr")
    
    ## ---- SIGNIFICANT GENES ----
    sig_up <- deg_results %>%
      dplyr::filter(adj.P.Val < fdr_cutoff & logFC > logfc_cutoff)

    sig_down <- deg_results %>%
      dplyr::filter(adj.P.Val < fdr_cutoff & logFC < -logfc_cutoff)

    ## ---- SAVE CSV ----
    out_csv <- paste0("DE_proteins_", cell_type, "_", gsub(":", "_", coef_name), ".csv")
    write.csv(deg_results, out_csv, row.names = TRUE)
    message("Saved: ", out_csv)

    ## ---- SAVE RDA ----
    dge_export <- list(
      full_DGE = deg_results,
      significant_up = sig_up,
      significant_down = sig_down
    )

    rda_filename <- paste0("DGE_", cell_type, "_", gsub(":", "_", coef_name), ".Rda")
    save(dge_export, file = rda_filename)
    message("Saved RDA: ", rda_filename)

    ## ---- VOLCANO PLOT ----
    png_filename <- paste0("Volcano_", cell_type, "_", gsub(":", "_", coef_name), ".png")
    png(png_filename, width = 1200, height = 1000)

    print(
      EnhancedVolcano(
        deg_results,
        lab = rownames(deg_results),
        x = 'logFC',
        y = 'P.Value',
        pCutoff = 0.05,
        FCcutoff = 1,
        title = paste("DE:", coef_name, "in", cell_type),
        subtitle = "limma model",
        legendLabels = c("NS", "Log2 FC", "p-value", "p & FC")
      )
    )

    dev.off()
    message("Saved volcano plot: ", png_filename)

  } else {
    warning("Coefficient ", coef_name, " not found in model.")
  }
}

```


#GSEA
```{r}
rm(list = ls())
library(dplyr)
library(fgsea)
library(clusterProfiler)
library(tibble)
#load("analysis/DGE_Astrocytes_haplotypeH1H1_A.Rda")
#load("analysis/DGE_Astrocytes_haplotypeH1H2.Rda")
#load("analysis/DGE_Neuron_haplotypeH1H1_A.Rda")
load("analysis/DGE_Neuron_haplotypeH1H2.Rda")

# Load Reactome pathways GMT file (adjust path if needed) 

Reactome <- read.gmt("c2.cp.kegg_legacy.v2023.2.Hs.symbols.gmt")

Reactome$term <- gsub("^KEGG_", "", Reactome$term)

dge_export <- dge_export$full_DGE
dge_export$hgnc_symbol <- rownames(dge_export)

# Prepare gene list from differential expression results (contrast_result)
gene_list <- dge_export %>%
  filter(!is.na(t), !is.na(hgnc_symbol)) %>%
  distinct(hgnc_symbol, .keep_all = TRUE) %>%
  arrange(desc(t)) %>%
  select(hgnc_symbol, t) %>%
  deframe()

gene_list <- gene_list[names(gene_list) != ""]

# Run GSEA
gsea_results <- GSEA(
  geneList = gene_list,
  TERM2GENE = Reactome,
  minGSSize = 10,
  maxGSSize = 500,
  pvalueCutoff = 0.05,
  verbose = TRUE
)

gsea_df <- as.data.frame(gsea_results)

#save(gsea_df, gsea_results, file = "gsea_H1_H2_AFR_Astro.rda")
#save(gsea_df, gsea_results, file = "gsea_H1_H1_A_AFR_Astro.rda")
#save(gsea_df, gsea_results, file = "gsea_H1_H1_A_AFR_Neuron.rda")
save(gsea_df, gsea_results, file = "gsea_H1_H2_AFR_Neuron.rda")

