# ----------------------------
# Significant pathways
# ----------------------------

# UP
H1A_up <- unique(gsea_H1A$Description[
  gsea_H1A$qvalue < 0.05 & gsea_H1A$NES > 0
])

H2_up <- unique(gsea_H2$Description[
  gsea_H2$qvalue < 0.05 & gsea_H2$NES > 0
])

# DOWN
H1A_down <- unique(gsea_H1A$Description[
  gsea_H1A$qvalue < 0.05 & gsea_H1A$NES < 0
])

H2_down <- unique(gsea_H2$Description[
  gsea_H2$qvalue < 0.05 & gsea_H2$NES < 0
])

# ----------------------------
# Build overlap tables
# ----------------------------

make_venn_table <- function(set1, set2, name1, name2, direction){

  shared <- intersect(set1, set2)
  only1  <- setdiff(set1, set2)
  only2  <- setdiff(set2, set1)

  data.frame(
    Regulation = direction,
    Category = c(
      rep(paste0("Shared_", name1, "_", name2), length(shared)),
      rep(paste0("Only_", name1), length(only1)),
      rep(paste0("Only_", name2), length(only2))
    ),
    Pathway = c(shared, only1, only2)
  )
}

table_up <- make_venn_table(
  H1A_up,
  H2_up,
  "H1A",
  "H1H2",
  "UP"
)

table_down <- make_venn_table(
  H1A_down,
  H2_down,
  "H1A",
  "H1H2",
  "DOWN"
)

final_table <- bind_rows(table_up, table_down)

# ----------------------------
# Export
# ----------------------------
write.csv(
  final_table,
  "Neuron_Venn_Pathways.csv",
  row.names = FALSE
)

print(final_table)
