library(patchwork)

# Extract GSEA result table
gsea_df <- gsea_results@result

# ---- Add significance stars ----
add_stars <- function(df) {
  df %>%
    mutate(star = case_when(
      qvalue < 0.001 ~ "***",
      qvalue < 0.01  ~ "**",
      qvalue < 0.05  ~ "*",
      TRUE           ~ ""
    ))
}

# Top 10 upregulated pathways (NES > 0)
gsea_up <- gsea_df %>%
  filter(NES > 0) %>%
  arrange(desc(NES)) %>%
  head(10) %>%
  add_stars()

