##cntplot
```{r}
library(DOSE)
library(clusterProfiler)
library(enrichplot)
library(dplyr)

# Extract results from GSEA object
gsea_df <- gsea_results@result

# Filter positive and negative NES pathways
gsea_df_pos <- filter(gsea_df, NES > 0)
gsea_df_neg <- filter(gsea_df, NES < 0)

# Clone GSEA objects
gsea_pos <- gsea_results
gsea_neg <- gsea_results

gsea_pos@result <- gsea_df_pos
gsea_neg@result <- gsea_df_neg

up_genes <- dge_export %>%
  filter(logFC > 0, P.Value < 0.05, !is.na(hgnc_symbol))

down_genes <- dge_export %>%
  filter(logFC < 0, P.Value < 0.05, !is.na(hgnc_symbol))

# Positive gene list from upregulated genes
geneList_p <- up_genes$logFC
names(geneList_p) <- up_genes$hgnc_symbol
geneList_p <- sort(geneList_p, decreasing = TRUE)

# Filter positive GSEA object core_enrichment genes by geneList_p
gsea_filtered_up <- gsea_pos
gsea_filtered_up@result$core_enrichment <- sapply(
  gsea_filtered_up@result$core_enrichment,
  function(genes_str) {
    genes <- unlist(strsplit(genes_str, "/"))
    genes_filt <- intersect(genes, names(geneList_p))
    paste(genes_filt, collapse = "/")
  }
)

# Remove pathways with empty core_enrichment
gsea_filtered_up@result <- gsea_filtered_up@result[gsea_filtered_up@result$core_enrichment != "", ]
gsea_filtered_up@geneSets <- lapply(gsea_filtered_up@result$core_enrichment, function(x) unlist(strsplit(x, "/")))
names(gsea_filtered_up@geneSets) <- gsea_filtered_up@result$ID

# Plot positive cnetplot
cnetplot_up <- cnetplot(
  gsea_filtered_up,
  showCategory = 2,
  foldChange = geneList_p,
  circular = FALSE,
  colorEdge = TRUE,
  label_size = 3
) + 
  scale_color_gradient(low = "white", high = "red", name = "logFC")

ggsave("cnetplot_up.pdf", plot = cnetplot_up, width = 12, height = 6)

# Negative gene list from downregulated genes
geneList_w <- down_genes$logFC
names(geneList_w) <- down_genes$hgnc_symbol
geneList_w <- sort(geneList_w, decreasing = TRUE)

# Filter negative GSEA object core_enrichment genes by geneList_w
gsea_filtered_dw <- gsea_neg
gsea_filtered_dw@result$core_enrichment <- sapply(
  gsea_filtered_dw@result$core_enrichment,
  function(genes_str) {
    genes <- unlist(strsplit(genes_str, "/"))
    genes_filt <- intersect(genes, names(geneList_w))
    paste(genes_filt, collapse = "/")
  }
)

# Remove empty pathways
gsea_filtered_dw@result <- gsea_filtered_dw@result[gsea_filtered_dw@result$core_enrichment != "", ]
gsea_filtered_dw@geneSets <- lapply(gsea_filtered_dw@result$core_enrichment, function(x) unlist(strsplit(x, "/")))
names(gsea_filtered_dw@geneSets) <- gsea_filtered_dw@result$ID

# Plot negative cnetplot
cnetplot_dw <- cnetplot(
  gsea_filtered_dw,
  showCategory = 2,
  foldChange = geneList_w,
  circular = FALSE,
  label_size = 3
) + 
  scale_color_gradient(low = "blue", high = "white", name = "logFC")

ggsave("cnetplot_dw.pdf", plot = cnetplot_dw, width = 12, height = 6)
