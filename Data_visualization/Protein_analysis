#CWP4 data processing
```{r}
rm(list = ls())
# Load necessary libraries
library(readxl)
library(dplyr)
library(limma)
library(EnhancedVolcano)

# Read in the data
data <- read_excel("proteomics_CWP4_final.xlsx")

# Extract metadata: assuming metadata is in the first ~15 rows and first ~10 columns
meta_raw <- data[1:7, 2:ncol(data)] #7 col of meta

meta_clean <- meta_raw[, -c(1:3)] #3 is before first full

meta<- as.data.frame(t(meta_clean))

colnames(meta) <- as.character(meta[1, ])
meta <- meta[-1, ]

# Export metadata to CSV (for external editing, e.g. in Excel)
write.csv(meta, "metadata_CWP4.csv")

# Read in edited metadata
#meta <- read.csv("metadata.csv", stringsAsFactors = FALSE)

# Assuming your data frame is called 'data'

# Extract the geneSym column (4th column)
geneSym_col <- data[, 4]

# Extract columns H (6) to end
cols_H_to_end <- data[, 6:ncol(data)]

# Combine geneSym_col as first column with columns H to N
result <- cbind(geneSym_col, cols_H_to_end)

# Optionally, rename first column for clarity
colnames(result)[1] <- "geneSym"
result <- result[-(1:8), ]
result <- result[!is.na(result$geneSym), ]
# Remove rows where geneSym is NA or the string "NA"
result <- result[!is.na(result$geneSym) & result$geneSym != "NA", ]

# If geneSym is a column in your dataframe:
result <- result[!duplicated(result$geneSym), ]

#result$geneSym <- make.unique(as.character(result$geneSym))
rownames(result) <- result$geneSym  # Set geneSym as rownames
result$geneSym <- NULL              # Remove geneSym column

write.csv(result, "data_CWP4.csv")
