```{r}
rm(list = ls())

library(dplyr)
library(tidyr)

# ----------------------------
# Function: build full GSEA table
# ----------------------------
make_gsea_table <- function(gsea_df) {

  base <- gsea_df %>%
    dplyr::select(
      Pathway = Description,
      NES,
      FDR = qvalue,
      core_enrichment
    )

  # split genes in core enrichment (always "/" in GSEA output)
  gene_list <- strsplit(base$core_enrichment, "/")

  # collapse into clean string
  base$Genes <- sapply(gene_list, function(g) {
    paste(g, collapse = "; ")
  })

  # final table (ALL pathways, no filtering)
  base %>%
    dplyr::select(Pathway, NES, FDR, Genes)
}

